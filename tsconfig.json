{
	"compilerOptions": {
		"target": "ES2020",
		"module": "commonjs",
		"lib": ["ES2020", "DOM"],
		"outDir": "dist",
		"rootDir": "src",
		"strict": true,
		"esModuleInterop": true,
		"skipLibCheck": true,
		"types": ["node", "jest", "react"],
		"jsx": "react-jsx",
		"jsxImportSource": "react"
	},
	"include": ["src"],
	"ts-node": {
		"transpileOnly": true,
		"files": true,
		"compilerOptions": {
			"module": "commonjs"
		}
	}
}
